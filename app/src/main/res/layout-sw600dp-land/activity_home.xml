<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_superman">

    <!-- 背景层 (用于全局同步) -->
    <ImageView
        android:id="@+id/ivBlurBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- 黑色半透明蒙层，用于提升文字可读性 -->
    <View
        android:id="@+id/vBackgroundScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000" />

    <!-- 左一：导航与内容 (1/3 宽度) -->
    <FrameLayout
        android:id="@+id/left_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/middle_panel">

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 悬浮底栏：与手机版布局逻辑一致 -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/bottom_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <!-- 中间：播放控制器 (1/3 宽度) - 完全仿照手机版布局 -->
    <include
        layout="@layout/layout_tablet_player_controls"
        android:id="@+id/middle_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@id/left_panel"
        app:layout_constraintEnd_toStartOf="@+id/right_panel" />

    <!-- 右侧：全屏歌词 (1/3 宽度) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/right_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@id/middle_panel"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/lyric_top_guideline"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLyricsRight"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="true"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/lyric_top_guideline"
            app:layout_constraintBottom_toTopOf="@id/lyric_bottom_guideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/lyric_bottom_guideline"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.kuangru52.embysic.HeartLayout
        android:id="@+id/heartLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
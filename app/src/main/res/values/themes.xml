<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Embysic" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorOnPrimary">@color/on_primary_light</item>
        <item name="colorPrimaryContainer">@color/primary_container_light</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container_light</item>

        <item name="colorSecondary">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/on_secondary_light</item>
        <item name="colorSecondaryContainer">@color/secondary_container_light</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container_light</item>

        <!-- 将背景设为 Superman 渐变 -->
        <item name="android:windowBackground">@drawable/bg_superman</item>
        <item name="colorSurface">@android:color/transparent</item>
        <item name="colorOnSurface">@color/on_surface_light</item>

        <!-- 核心修复：确保文字颜色跟随主题 -->
        <item name="android:textColorPrimary">@color/on_surface_light</item>
        <item name="android:textColorSecondary">#6D5D59</item>
        <item name="colorOnSurfaceVariant">#6D5D59</item>
    </style>

    <style name="Theme.Embysic" parent="Base.Theme.Embysic" />

    <style name="Theme.PlayerBottomSheet" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearance">@null</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 播放页专用动画样式 -->
    <style name="PlayerDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>

    <!-- 侧滑退出专用动画样式 -->
    <style name="PlayerDialogSwipeExitAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/ios_slide_out_right</item>
    </style>
</resources>
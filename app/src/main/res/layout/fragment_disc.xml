<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/rlDiscContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/rlDisc"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_centerInParent="true">

            <ImageView
                android:id="@+id/ivDisc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/disk"
                android:scaleType="fitCenter" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cvCover"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                app:cardCornerRadius="100dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivFullCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <ImageView
            android:id="@+id/ivNeedle"
            android:layout_width="100dp"
            android:layout_height="160dp"
            android:layout_centerHorizontal="true"
            android:layout_alignTop="@id/rlDisc"
            android:layout_marginTop="-70dp"
            android:translationX="60dp"
            android:src="@drawable/styli2"
            android:scaleType="fitCenter"
            android:transformPivotX="25dp"
            android:transformPivotY="25dp" />
    </RelativeLayout>
</FrameLayout>
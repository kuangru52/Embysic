<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#4DFFFFFF">
    <item>
        <layer-list>
            <!-- 1. 模拟玻璃边缘的折射暗影 -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#0D000000" />
                    <padding android:bottom="2dp" android:right="2dp" />
                </shape>
            </item>
            <!-- 2. 玻璃主体 -->
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:type="radial"
                        android:gradientRadius="40dp"
                        android:startColor="#26FFFFFF"
                        android:endColor="#1AFFFFFF" />
                    <!-- 3. 极细的高光边缘 (液态玻璃的核心) -->
                    <stroke
                        android:width="1.2dp"
                        android:color="#4DFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <FrameLayout
        android:id="@+id/rlDiscContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/rlDisc"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/ivDisc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/disk"
                android:scaleType="fitCenter" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cvCover"
                android:layout_width="196dp"
                android:layout_height="196dp"
                android:layout_gravity="center"
                app:cardCornerRadius="98dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivFullCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:src="@android:drawable/ic_menu_gallery" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <ImageView
            android:id="@+id/ivNeedle"
            android:layout_width="100dp"
            android:layout_height="160dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="-20dp"
            android:translationX="60dp"
            android:src="@drawable/styli2"
            android:scaleType="fitCenter"
            android:transformPivotX="28dp"
            android:transformPivotY="28dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvFullTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        tools:text="Song Title" />

    <TextView
        android:id="@+id/tvFullArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E0FFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        tools:text="Artist Name" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeProgressBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_previous_vector"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnPlayPauseFull"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play_vector"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_next_vector"
            app:tint="@android:color/white" />
    </LinearLayout>
</LinearLayout>
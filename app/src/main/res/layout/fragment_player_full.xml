<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_full"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/ivBlurBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.6"
        tools:ignore="ContentDescription" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp">

        <!-- 封面图与歌词容器 -->
        <FrameLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 唱片机容器 -->
            <RelativeLayout
                android:id="@+id/rlDiscContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 唱片黑胶旋转容器 -->
                <FrameLayout
                    android:id="@+id/rlDisc"
                    android:layout_width="330dp"
                    android:layout_height="330dp"
                    android:layout_centerInParent="true">

                    <ImageView
                        android:id="@+id/ivDisc"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/disk"
                        android:scaleType="fitCenter" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvCover"
                        android:layout_width="216dp"
                        android:layout_height="216dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="108dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/ivFullCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            tools:src="@android:drawable/ic_menu_gallery" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>

                <!-- 唱针 -->
                <ImageView
                    android:id="@+id/ivNeedle"
                    android:layout_width="110dp"
                    android:layout_height="180dp"
                    android:layout_centerHorizontal="true"
                    android:layout_alignTop="@id/rlDisc"
                    android:layout_marginTop="-80dp"
                    android:translationX="65dp"
                    android:src="@drawable/styli2"
                    android:scaleType="fitCenter"
                    android:transformPivotX="28dp"
                    android:transformPivotY="28dp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLyrics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:paddingTop="200dp"
                android:paddingBottom="200dp"
                android:clipToPadding="false" />
        </FrameLayout>

        <!-- 信息区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFullTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Song Title"
                    android:textColor="@android:color/white"
                    android:shadowColor="#80000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:ellipsize="marquee"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/tvFullArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Artist Name"
                    android:textColor="#E0FFFFFF"
                    android:textSize="18sp"
                    android:ellipsize="marquee"
                    android:singleLine="true"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:scrollHorizontally="true" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_heart_border"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- 播放质量标签 -->
        <TextView
            android:id="@+id/tvAudioQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            tools:text="AAC 256kbps" />

        <!-- 下载进度条 -->
        <ProgressBar
            android:id="@+id/pbDownload"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:progress="0"
            android:max="100"
            android:visibility="gone"
            android:progressTint="?attr/colorPrimary"
            android:progressBackgroundTint="?attr/colorSurfaceVariant" />

        <!-- 进度条区域 -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:background="@null"
            android:splitTrack="false"
            android:stateListAnimator="@null"
            android:progressTint="?attr/colorPrimary"
            android:thumbTint="?attr/colorPrimary" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0:00"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </RelativeLayout>

        <!-- 控制按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_skip_previous_vector"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/btnPlayPauseFull"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginHorizontal="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_play_vector"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_skip_next_vector"
                app:tint="@android:color/white" />

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
